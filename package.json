  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^30.0.0",
    "jest-junit": "^16.0.0",
    "prettier-config-standard": "^7.0.0",
    "prettier-plugin-multiline-arrays": "^4.1.5",
    "ts-jest": "^29.4.0",
