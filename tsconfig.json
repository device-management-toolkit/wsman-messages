{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "moduleResolution": "nodenext",
    "declaration": true,
    "module": "nodenext",
    "target": "es2022",
    "strict": true,
    "isolatedModules": true,
    "types": ["vitest/globals"]
  },

  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "./src/**/*.test.ts"
  ]
}
